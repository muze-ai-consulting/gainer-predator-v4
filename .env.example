# ============================================
# Gainer Predator V4 — Configuration
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# --- Binance API ---
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
USE_TESTNET=true

# --- Bot Mode ---
BOT_MODE=scanner

# --- Strategy Parameters ---
RVOL_THRESHOLD=2.0
JUMP_MIN_PCT=0.5
JUMP_MAX_PCT=15.0
GOOD_HOURS=1,2,5,6,9,10,11,13,14,21

# --- Risk Management ---
MAX_POSITIONS=3
POSITION_SIZE_PCT=20.0
DEFAULT_LEVERAGE=10
MARGIN_TYPE=CROSSED
STOP_LOSS_PCT=0.015
MAX_HOLD_SECS=21600

# --- Trailing Stop (Apex Exit) ---
APEX_RETRACEMENT=0.005
APEX_ACTIVATION_PCT=0.0
APEX_TIGHT_ACTIVATION_PCT=0.003
APEX_TIGHT_RETRACEMENT=0.003

# --- Scanner ---
SCAN_INTERVAL_SECS=60
UNIVERSE_SIZE=50

# --- HTTP API ---
HTTP_PORT=3001

# --- Logging ---
RUST_LOG=info
